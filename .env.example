# Cloudflare Worker deployment
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
WORKER_NAME=aws-pricing-calculator-mcp
WORKER_ENV=
WRANGLER_CONFIG=./wrangler.toml

# Optional CORS allowlist for browser-based MCP clients.
# Leave blank to allow any Origin.
MCP_ALLOWED_ORIGINS=

# Optional bearer auth for the remote /mcp endpoint.
# Leave blank for local/dev use, or set for hosted deployments.
MCP_BEARER_TOKEN=
