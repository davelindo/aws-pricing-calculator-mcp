    {
      "name": "list_blueprints",
      "description": "List the blueprint catalog supported by the architecture engine.",
      "inputSchemaId": null,
      "outputSchemaId": "aws-pricing-calculator-mcp.contract.v1.tools.list_blueprints.output"
    },
    {
      "name": "list_service_catalog",
      "description": "List the service registry with per-region capability states and implementation status.",
      "inputSchemaId": null,
      "outputSchemaId": "aws-pricing-calculator-mcp.contract.v1.tools.list_service_catalog.output"
    },
    {
      "name": "design_architecture",
      "description": "Normalize a blueprint or rough brief into an architecture spec with explicit service capabilities and default scenario policies.",
      "inputSchemaId": "aws-pricing-calculator-mcp.contract.v1.tools.design_architecture.input",
      "outputSchemaId": "aws-pricing-calculator-mcp.contract.v1.tools.design_architecture.output"
    },
    {
      "name": "price_architecture",
      "description": "Preview priced scenarios for an architecture and return calculator commit handles for exact scenarios. Use generate_calculator_link for the default one-shot flow, or create_calculator_link to commit a selected priced scenario.",
      "inputSchemaId": "aws-pricing-calculator-mcp.contract.v1.tools.price_architecture.input",
      "outputSchemaId": "aws-pricing-calculator-mcp.contract.v1.tools.price_architecture.output"
    },
    {
      "name": "generate_calculator_link",
      "description": "Default happy path for chat clients: design if needed, price scenarios, pick a calculator-eligible scenario, create the official AWS calculator share link, and validate the saved estimate.",
      "inputSchemaId": "aws-pricing-calculator-mcp.contract.v1.tools.generate_calculator_link.input",
      "outputSchemaId": "aws-pricing-calculator-mcp.contract.v1.tools.generate_calculator_link.output"
    },
    {
      "name": "create_calculator_link",
      "description": "Commit a previously priced exact scenario to AWS Pricing Calculator by passing its pricingCommit handle, then validate the saved estimate.",
      "inputSchemaId": "aws-pricing-calculator-mcp.contract.v1.tools.create_calculator_link.input",
      "outputSchemaId": "aws-pricing-calculator-mcp.contract.v1.tools.create_calculator_link.output"
    },
    {
      "name": "validate_calculator_link",
      "description": "Validate an AWS calculator share link for pricing integrity, architecture completeness, and funding readiness.",
      "inputSchemaId": "aws-pricing-calculator-mcp.contract.v1.tools.validate_calculator_link.input",
      "outputSchemaId": "aws-pricing-calculator-mcp.contract.v1.tools.validate_calculator_link.output"
    }
